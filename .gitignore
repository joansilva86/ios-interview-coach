# macOS
.DS_Store
* copy*

# Claude Code local settings (machine-specific paths) — but track the skills,
# they are the project's core logic. Note: must be `.claude/*` (not `.claude/`)
# so the !.claude/skills/ re-include can take effect.
.claude/*
!.claude/skills/

# Personal session logs (local-only, not shared)
logs/

# Per-candidate topic list (created by /interview-helper on cold start, owned by /interview-setup-session)
current_topics.csv

# Personal candidate information (local-only; not shared via git)
candidate-information/
